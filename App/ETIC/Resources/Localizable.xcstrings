    "board.interpretationDesc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Submit this hexagram to a veteran Liuyao diviner for a detailed reading with multi-turn follow-up. The chart is fixed — the reading does not alter it."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将此卦呈递资深六爻师傅进行详细解读，支持多轮追问。盘面不变 — 解读不会改动卦象。"
          }
        }
      }
    },
    "board.legend" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "○ Old Yang (moving)   × Old Yin (moving)   Self/Other mark the subject   Void marks the empty branch   Flourishing/Waning/Ideal/Confined/Dead indicates monthly strength"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "○ 老阳（动爻）  × 老阴（动爻）  世/应标注主客  旬空标注空亡地支  旺/衰/相/囚/死表示月建旺衰"
          }
        }
      }
    },

    "casting.hint.coins" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Shake your phone or tap the button — three coins settle six times, building the hexagram from bottom to top."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "摇动手机或点击按钮 — 三枚铜钱抛掷六次，从下往上逐爻排定。"
          }
        }
      }
    },
    "casting.hint.number" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plum Blossom method: take innate trigram from the upper and lower numbers; their sum determines the moving line."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "梅花易数：取上数字为外卦，下数字为内卦，两数之和定动爻。"
          }
        }
      }
    },
    "casting.hint.random" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The system simulates a coin toss randomly for a quick experience."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "系统随机模拟铜钱起卦，快速体验。"

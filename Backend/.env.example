# ETIC 解读后端配置（复制为 .env；切勿提交真实 key）
# Provider 用 OpenAI 兼容协议，切换 provider 只需改 base_url + model + key。

# DeepSeek（默认，国产合规、便宜）
ETIC_LLM_BASE_URL=https://api.deepseek.com/v1
ETIC_LLM_MODEL=deepseek-chat
ETIC_LLM_API_KEY=

# 通义千问（OpenAI 兼容）示例：
# ETIC_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ETIC_LLM_MODEL=qwen-plus

# OpenAI 示例：
# ETIC_LLM_BASE_URL=https://api.openai.com/v1
# ETIC_LLM_MODEL=gpt-4o-mini

ETIC_LLM_TEMPERATURE=0.7
ETIC_LLM_TIMEOUT_SECONDS=60

# 无 key 时自动 mock；也可强制开启 mock 做本地联调。
ETIC_MOCK_LLM=false

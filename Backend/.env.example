# ETIC 解读后端配置（复制为 .env；切勿提交真实 key）
# Provider 用 OpenAI 兼容协议，切换 provider 只需改 base_url + model + key。

# DeepSeek（默认，国产合规、便宜）
ETIC_LLM_BASE_URL=https://api.deepseek.com/v1
ETIC_LLM_MODEL=deepseek-chat
ETIC_LLM_API_KEY=

# 通义千问（OpenAI 兼容）示例：
# ETIC_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ETIC_LLM_MODEL=qwen-plus

# OpenAI 示例：
# ETIC_LLM_BASE_URL=https://api.openai.com/v1
# ETIC_LLM_MODEL=gpt-4o-mini

ETIC_LLM_TEMPERATURE=0.7
ETIC_LLM_TIMEOUT_SECONDS=60

# 无 key 时自动 mock；也可强制开启 mock 做本地联调。
ETIC_MOCK_LLM=false

# ---- 内容安全审核（M6）----
# 开启后，起卦问题 / 追问文本先过确定性审核：高危类（自伤、伤人、违法等）直接拒绝、
# 不调用 LLM 并回本地化安全提示；敏感类（重病 / 诉讼 / 投资等）放行但注入更强去绝对化约束。
ETIC_MODERATION_ENABLED=true

# ---- RAG（卦爻辞检索 grounding，M5）----
# 开启后解读前会按本卦/变卦/动爻检索周易经文拼入 Prompt。需先 docker compose up -d 并 python scripts/ingest.py 灌库。
ETIC_RAG_ENABLED=false
ETIC_DATABASE_URL=postgresql://etic:etic@localhost:5432/etic

# embeddings（OpenAI 兼容 /embeddings；留空则回退到上面的 LLM key/base_url）。
# 无 embeddings key 时用确定性 mock 向量，可离线灌库与联调。
ETIC_EMBED_BASE_URL=
ETIC_EMBED_MODEL=text-embedding-3-small
ETIC_EMBED_API_KEY=
# mock 与真实 provider 维度须一致；切换 provider 后需重新灌库。
# 真实 text-embedding-3-small 维度为 1536；mock 默认 256。
ETIC_EMBED_DIM=256

# 向量召回条数；是否附带彖辞。
ETIC_RAG_TOP_K=4
ETIC_RAG_INCLUDE_TUAN=false

# ---- 账号 & 计费（M6）----
# Apple Sign In 验签：identity token 的 audience 为 bundle ID。
ETIC_APPLE_BUNDLE_ID=ai.etic.app
# 后端签发会话 JWT 的密钥（随机长字符串，切勿泄露）。请用 `openssl rand -hex 32` 生成。
ETIC_JWT_SECRET=
# 会话 JWT 有效期（天）。
ETIC_JWT_EXPIRE_DAYS=30
# 每月免费解读次数。
ETIC_FREE_MONTHLY_CREDITS=3
# 每次解读最多追问次数。
ETIC_MAX_QUESTIONS_PER_READING=3
# 订阅每月赠送额度（解读时正常抵扣，非无限畅读）。
ETIC_SUBSCRIPTION_MONTHLY_CREDITS=30
# 计费系统是否启用（关闭时 interpret/chat 不鉴权、不扣费，兼容旧流程）。
ETIC_BILLING_ENABLED=false
# 开发模式：启用测试登录端点（POST /v1/auth/test），跳过 Apple 验签。生产环境务必设为 false。
ETIC_DEV_MODE=false

# StoreKit 商品 ID（需与 App Store Connect 中配置一致）。
ETIC_SUBSCRIPTION_PRODUCT_ID=ai.etic.app.subscription.monthly
# 充值商品 ID → 额度数映射，格式 "product_id:credits,..."
ETIC_TOPUP_PRODUCTS=ai.etic.app.credits.5:5,ai.etic.app.credits.10:10,ai.etic.app.credits.25:25

# ---- Apple 密钥（Sign in with Apple / App Store Server Notifications）----
# Apple Developer Team ID（Membership 页面可查，10 位字母数字）。
ETIC_APPLE_TEAM_ID=
# Sign in with Apple 私钥 Key ID（用于生成 client_secret）。
ETIC_APPLE_SIWA_KEY_ID=
ETIC_APPLE_SIWA_KEY_PATH=keys/logo-in/AuthKey_XXXXX.p8
# App Store Server Notifications 验签私钥路径。生产/沙盒各一个 APNs Key。
ETIC_APPLE_NOTIFICATION_PROD_KEY_PATH=keys/notification/production/AuthKey_XXXXX.p8
ETIC_APPLE_NOTIFICATION_SANDBOX_KEY_PATH=keys/notification/sandbox/AuthKey_XXXXX.p8
